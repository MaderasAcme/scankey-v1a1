{
  "name": "scankey-pro",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host --port 5173",
    "build:web": "vite build",
    "preview:web": "vite preview --host --port 5173",
    "expo:start": "expo start",
    "expo:web": "expo start --web --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:preview": "eas build -p android --profile preview",
    "build:prod": "eas build -p android --profile production",
    "qa:contract": "node scripts/contract_check.js scripts/sample_responses/normal.json",
    "qa:secrets": "bash scripts/verify_no_secrets.sh",
    "qa:smoke": "bash scripts/smoke_test_backend.sh",
    "qa:all": "npm run qa:contract && npm run qa:secrets && npm run qa:smoke"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "lucide-react": "^0.378.0",
    "nativewind": "^4.2.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.1",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "babel-preset-expo": "^55.0.10",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
