# URL del Gateway (sin barra final)
# VITE_GATEWAY_BASE_URL=http://localhost:8080

# API key opcional (para gateway local/prod)
# VITE_API_KEY=local-dev-key

# Login taller (gateway ENV, no frontend)
# WORKSHOP_LOGIN_EMAIL=
# WORKSHOP_LOGIN_PASSWORD=
# WORKSHOP_TOKEN=

# Ejemplo prod:
# VITE_GATEWAY_BASE_URL=https://TU_GATEWAY_AQUI
# No pongas API keys en el front. Usa .env.local para dev si hace falta.