# ScanKey - Variables de entorno (SIN secretos)
# Copia a .env.local y ajusta. .env.local está en .gitignore.
# SOLO para desarrollo local; nunca usar en prod.

# --- Puertos (compose local) ---
GATEWAY_PORT=8080
MOTOR_PORT=8081

# --- Motor (para gateway dentro de compose) ---
MOTOR_URL=http://motor:8080

# --- OCR (vacío por defecto) ---
OCR_URL=

# --- Features ---
SCN_FEATURE_AB_FUSION_ENABLED=true
SCN_FEATURE_OCR_ON_DEMAND_ENABLED=true
# P0.2 QualityGate PASIVO (default true)
SCN_FEATURE_QUALITY_GATE_PASSIVE=true
# P0.3 Risk Engine PASIVO (default true)
SCN_FEATURE_RISK_ENGINE_PASSIVE=true

# --- Local dev (SOLO desarrollo, nunca prod) ---
# SCN_LOCAL_DEV=1 activa modo local
# SCN_MOCK_ENGINE=1 si no hay ONNX (motor simulado)
# API_KEYS debe incluir local-dev-key solo en local
API_KEYS=local-dev-key
SCN_MOCK_ENGINE=1
SCN_LOCAL_DEV=1

# --- OCR taller (P0.1) ---
# WORKSHOP_TOKEN=  (sin valor en repo; configura en prod para habilitar ocr_detail con X-Workshop-Token)

# --- CORS (gateway) ---
# ALLOWED_ORIGINS=http://localhost:5173,https://maderasacme.github.io

# --- UI (Vite) - en ui-studio/.env o ui-studio/.env.local ---
# VITE_GATEWAY_BASE_URL=http://localhost:8080
# VITE_API_KEY=local-dev-key
